---
import { getCollection, render } from "astro:content";
import { marked } from "marked";
import BaseLayout from "../../layouts/BaseLayout.astro";
import SmartImage from "../../components/SmartImage.astro";

// One static page per project, generated at build time.
export async function getStaticPaths() {
  const projects = await getCollection("projects", ({ data }) => !data.draft);
  return projects.map((project) => ({
    params: { slug: project.id },
    props: { project },
  }));
}

const { project } = Astro.props;
const { title, description, year, role, client, tags, url, blocks } = project.data;
const { Content } = await render(project);

// Render the markdown body only if there's actual text after the frontmatter.
const hasBody = (project.body ?? "").trim().length > 0;

// Tailwind column classes per gallery layout.
const galleryCols: Record<string, string> = {
  "grid-2": "sm:grid-cols-2",
  "grid-3": "sm:grid-cols-3",
  full: "grid-cols-1",
};
---

<BaseLayout title={`${title} — Su`} description={description}>
  <main class="w-full px-6 pt-32 pb-24 sm:px-10 lg:px-16">
    <div class="mx-auto w-full max-w-[1600px]">
      <a
        href="/#work"
        class="font-mono text-xs uppercase tracking-widest text-neutral-500 transition-colors hover:text-neutral-900"
      >
        ← Back to work
      </a>
      <header class="mt-10 max-w-4xl" data-reveal>
        <h1 class="font-medium leading-[0.98] tracking-[-0.02em] text-[clamp(2.25rem,6vw,5.5rem)]">
          {title}
        </h1>
        <p class="mt-6 max-w-2xl text-lg text-neutral-500">{description}</p>

        <dl class="mt-10 grid grid-cols-2 gap-6 border-t border-neutral-300 pt-8 sm:grid-cols-4">
          <div>
            <dt class="font-mono text-xs uppercase tracking-widest text-neutral-500">Year</dt>
            <dd class="mt-1 text-neutral-900">{year}</dd>
          </div>
          {role && (
            <div>
              <dt class="font-mono text-xs uppercase tracking-widest text-neutral-500">Role</dt>
              <dd class="mt-1 text-neutral-900">{role}</dd>
            </div>
          )}
          {client && (
            <div>
              <dt class="font-mono text-xs uppercase tracking-widest text-neutral-500">Client</dt>
              <dd class="mt-1 text-neutral-900">{client}</dd>
            </div>
          )}
          {tags.length > 0 && (
            <div class="col-span-2">
              <dt class="font-mono text-xs uppercase tracking-widest text-neutral-500">
                Discipline
              </dt>
              <dd class="mt-1 text-neutral-900">{tags.join(", ")}</dd>
            </div>
          )}
        </dl>

        {url && (
          <a
            href={url}
            target="_blank"
            rel="noopener noreferrer"
            class="mt-8 inline-block text-sm text-neutral-900 underline underline-offset-4 hover:text-neutral-500"
          >
            Visit live project ↗
          </a>
        )}
      </header>
      {hasBody && (
        <article class="prose mt-16" data-reveal>
          <Content />
        </article>
      )}
      {blocks.map((block) =>
        block.type === "text" ? (
          <section class="mt-20 max-w-2xl" data-reveal>
            {block.heading && (
              <h2 class="mb-4 text-2xl font-medium tracking-tight sm:text-3xl">
                {block.heading}
              </h2>
            )}
            <div class="prose" set:html={marked.parse(block.body) as string} />
          </section>
        ) : (
          <section class="mt-20">
            <div data-card-group class:list={["grid gap-4", galleryCols[block.layout]]}>
              {block.images.map((img, i) => (
                <div
                  data-card
                  class="overflow-hidden rounded-xl bg-neutral-200"
                >
                  <SmartImage
                    src={img}
                    alt={`${title} — image ${i + 1}`}
                    widths={[600, 1200, 1800]}
                    sizes="(min-width: 640px) 100vw, 100vw"
                    class="h-full w-full object-cover"
                  />
                </div>
              ))}
            </div>
            {block.caption && (
              <p class="mt-3 font-mono text-xs uppercase tracking-widest text-neutral-500">
                {block.caption}
              </p>
            )}
          </section>
        )
      )}
    </div>
  </main>
</BaseLayout>
