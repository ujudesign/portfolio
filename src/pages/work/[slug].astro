---
import { getCollection, render } from "astro:content";
import { Image } from "astro:assets";
import BaseLayout from "../../layouts/BaseLayout.astro";

// One static page per project, generated at build time.
export async function getStaticPaths() {
  const projects = await getCollection("projects", ({ data }) => !data.draft);
  return projects.map((project) => ({
    params: { slug: project.id },
    props: { project },
  }));
}

const { project } = Astro.props;
const { title, description, year, role, client, tags, gallery, url } = project.data;
const { Content } = await render(project);
---

<BaseLayout title={`${title} — Su`} description={description}>
  <main class="mx-auto max-w-5xl px-6 pt-32 pb-24">
    <a href="/#work" class="text-sm text-neutral-500 transition-colors hover:text-neutral-100">
      ← Back to work
    </a>

    <!-- Title block -->
    <header class="mt-8 max-w-3xl" data-reveal>
      <h1 class="text-4xl font-semibold tracking-tight sm:text-6xl">{title}</h1>
      <p class="mt-4 text-lg text-neutral-400">{description}</p>

      <dl class="mt-8 grid grid-cols-2 gap-6 border-t border-neutral-800 pt-8 sm:grid-cols-4">
        <div>
          <dt class="text-xs uppercase tracking-widest text-neutral-500">Year</dt>
          <dd class="mt-1 text-neutral-200">{year}</dd>
        </div>
        {role && (
          <div>
            <dt class="text-xs uppercase tracking-widest text-neutral-500">Role</dt>
            <dd class="mt-1 text-neutral-200">{role}</dd>
          </div>
        )}
        {client && (
          <div>
            <dt class="text-xs uppercase tracking-widest text-neutral-500">Client</dt>
            <dd class="mt-1 text-neutral-200">{client}</dd>
          </div>
        )}
        {tags.length > 0 && (
          <div class="col-span-2">
            <dt class="text-xs uppercase tracking-widest text-neutral-500">Discipline</dt>
            <dd class="mt-1 text-neutral-200">{tags.join(", ")}</dd>
          </div>
        )}
      </dl>

      {url && (
        <a
          href={url}
          target="_blank"
          rel="noopener noreferrer"
          class="mt-6 inline-block text-sm text-neutral-100 underline underline-offset-4 hover:text-neutral-400"
        >
          Visit live project ↗
        </a>
      )}
    </header>

    <!-- Case-study body (markdown) -->
    <article class="prose mt-16" data-reveal>
      <Content />
    </article>

    <!-- Image grid -->
    {
      gallery.length > 0 && (
        <section data-card-group class="mt-16 grid gap-4 sm:grid-cols-2">
          {gallery.map((img, i) => (
            <div
              data-card
              class:list={[
                "overflow-hidden rounded-xl border border-neutral-800 bg-neutral-900",
                // Let the first image span full width for a nice rhythm.
                i === 0 && "sm:col-span-2",
              ]}
            >
              <Image
                src={img}
                alt={`${title} — image ${i + 1}`}
                widths={[600, 1200, 1800]}
                sizes="(min-width: 640px) 100vw, 100vw"
                class="h-full w-full object-cover"
              />
            </div>
          ))}
        </section>
      )
    }
  </main>
</BaseLayout>
