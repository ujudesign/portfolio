---
import { getCollection, render } from "astro:content";
import { marked } from "marked";
import BaseLayout from "../../layouts/BaseLayout.astro";

// One static page per project, generated at build time.
export async function getStaticPaths() {
  const projects = await getCollection("projects", ({ data }) => !data.draft);
  return projects.map((project) => ({
    params: { slug: project.id },
    props: { project },
  }));
}

const { project } = Astro.props;
const { title, description, year, role, agency, client, tags, url, thumbnail, thumbnailHover, blocks } =
  project.data;
const { Content } = await render(project);

// Render the markdown body only if there's actual text after the frontmatter.
const hasBody = (project.body ?? "").trim().length > 0;

// Resolve an image field (local ImageMetadata or remote URL string) to a plain
// static URL — bypasses Astro's runtime image endpoint so it works on any host.
const src = (img) => (typeof img === "string" ? img : img?.src);

// Left-column meta pairs (only the ones that are set).
const meta = [
  { label: "Year", value: String(year) },
  role && { label: "Role", value: role },
  agency && { label: "Agency", value: agency },
  client && { label: "Client", value: client },
  tags.length > 0 && { label: "Discipline", value: tags.join(", ") },
].filter(Boolean);

// Tailwind column classes per gallery layout.
const galleryCols: Record<string, string> = {
  "grid-2": "sm:grid-cols-2",
  "grid-3": "sm:grid-cols-3",
  full: "grid-cols-1",
};
---

<BaseLayout title={`${title} — Suthan`} description={description} enterCurtain={true}>
  <main class="min-h-screen bg-[#0a0a0a] text-white">
    <div
      class="grid w-full px-[clamp(1rem,1.6vw,2.5rem)] lg:grid-cols-[calc(50%_-_clamp(7.5rem,11.5vw,21rem))_1fr]"
    >
      {/* Left: sticky project meta */}
      <div class="relative [container-type:inline-size]">
        <div
          class="flex flex-col pt-[clamp(3.5rem,7vh,6.5rem)] pb-16 pr-[clamp(2rem,5.2vw,7rem)] lg:sticky lg:top-0 lg:h-screen"
        >
          <h1
            data-case-reveal
            class="font-normal leading-[1.1] tracking-[-0.5px] text-[clamp(1.75rem,4.3cqw,4.25rem)]"
          >
            {title}
          </h1>
          <p
            data-case-reveal
            class="mt-6 text-[clamp(0.8rem,0.9vw,1.1rem)] leading-[1.4] text-white"
          >
            {description}
          </p>

          <dl class="mt-10 grid grid-cols-2 gap-x-8 gap-y-8">
            {meta.map((m) => (
              <div data-case-reveal>
                <dt class="mb-3 font-mono text-[10px] uppercase tracking-[0.06em] text-muted">
                  {m.label}
                </dt>
                <dd class="leading-[1.3] text-[clamp(0.75rem,0.8vw,0.9rem)] text-neutral-400">
                  {m.value}
                </dd>
              </div>
            ))}
          </dl>

          {url && (
            <a
              href={url}
              target="_blank"
              rel="noopener noreferrer"
              class="mt-10 inline-block font-mono text-[10px] uppercase tracking-[0.06em] text-muted transition-colors hover:text-white"
            >
              Visit live project ↗
            </a>
          )}
        </div>
      </div>

      {/* Right: hero image, optional overview, then content blocks */}
      <div class="flex flex-col gap-[clamp(2.5rem,6vh,6rem)] pt-[clamp(3.5rem,7vh,6.5rem)] pb-[clamp(6rem,16vh,14rem)]">
        <div data-enter-fade class="aspect-[16/10] w-full overflow-hidden bg-neutral-800">
          <img src={src(thumbnail)} alt={title} class="h-full w-full object-cover" />
        </div>

        {thumbnailHover && (
          <div data-enter-fade class="aspect-[16/10] w-full overflow-hidden bg-neutral-800">
            <img src={src(thumbnailHover)} alt={title} class="h-full w-full object-cover" />
          </div>
        )}

        {hasBody && (
          <div data-reveal class="prose prose-invert max-w-none">
            <Content />
          </div>
        )}

        {blocks.map((block) =>
          block.type === "text" ? (
            <div data-reveal>
              {block.heading && (
                <h2 class="mb-4 font-normal tracking-[-0.5px] text-[clamp(1.25rem,1.6vw,1.75rem)]">
                  {block.heading}
                </h2>
              )}
              <div
                class="prose prose-invert max-w-none"
                set:html={marked.parse(block.body) as string}
              />
            </div>
          ) : (
            <div>
              <div data-card-group class:list={["grid gap-4", galleryCols[block.layout]]}>
                {block.images.map((img, i) => (
                  <div
                    data-card
                    class:list={[
                      "overflow-hidden bg-neutral-800",
                      block.layout === "full" ? "aspect-[16/10]" : "aspect-[4/3]",
                    ]}
                  >
                    <img
                      src={src(img)}
                      alt={`${title} — image ${i + 1}`}
                      class="h-full w-full object-cover"
                    />
                  </div>
                ))}
              </div>
              {block.caption && (
                <p class="mt-3 font-mono text-[10px] uppercase tracking-[0.06em] text-muted">
                  {block.caption}
                </p>
              )}
            </div>
          )
        )}
      </div>
    </div>
  </main>
</BaseLayout>
