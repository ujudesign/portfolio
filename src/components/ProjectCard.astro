---
import SmartImage from "./SmartImage.astro";
import type { CollectionEntry } from "astro:content";

interface Props {
  project: CollectionEntry<"projects">;
  index: number;
}

const { project, index } = Astro.props;
const { title, description, year, tags, thumbnail } = project.data;
const idx = String(index).padStart(2, "0");
const meta = [year, ...(tags ?? [])].join(" — ");
---

<a href={`/work/${project.id}`} data-card class="group block">
  <div class="relative w-full overflow-hidden rounded-xl bg-neutral-200 aspect-[16/10]">
    <SmartImage
      src={thumbnail}
      alt={title}
      widths={[800, 1400, 2000]}
      sizes="100vw"
      class="h-full w-full object-cover transition-transform duration-700 ease-out group-hover:scale-[1.03]"
    />
    <span class="absolute left-5 top-5 font-mono text-xs text-white mix-blend-difference">
      {idx}
    </span>
  </div>
  <div class="mt-6 flex flex-col gap-2 sm:flex-row sm:items-baseline sm:justify-between">
    <h3 class="text-3xl font-medium tracking-tight sm:text-5xl">{title}</h3>
    <span class="shrink-0 font-mono text-xs uppercase tracking-widest text-neutral-500">
      {meta}
    </span>
  </div>
  <p class="mt-3 max-w-xl text-neutral-500">{description}</p>
</a>
