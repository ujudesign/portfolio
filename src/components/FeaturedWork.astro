---
import { getCollection } from "astro:content";

const featured = (
  await getCollection("projects", ({ data }) => data.featured && !data.draft)
).sort((a, b) => b.data.year - a.data.year);

// Resolve an image field (local ImageMetadata or remote URL string) to a plain
// static URL — bypasses Astro's runtime image endpoint so it works on any host.
const url = (img) => (typeof img === "string" ? img : img?.src);

const first = featured[0];
const years = featured.map((f) => f.data.year);
const lo = String(Math.min(...years) % 100).padStart(2, "0");
const hi = String(Math.max(...years) % 100).padStart(2, "0");
---

{
  featured.length > 0 && (
    <section data-featured class="relative bg-[#e2e2e2] text-[#0a0a0a]">
      {/* Elastic top edge: bows up into the hero with scroll velocity, springs flat */}
      <svg
        data-stretch
        aria-hidden="true"
        class="pointer-events-none absolute inset-x-0 bottom-full h-[110px] w-full"
        viewBox="0 0 1000 100"
        preserveAspectRatio="none"
      >
        <path data-stretch-path fill="#e2e2e2" d="M0,100 Q500,100 1000,100 Z" />
      </svg>

      {/* Left column ends at the hero portrait's left edge: 50% minus half the portrait width */}
      <div class="grid w-full px-[clamp(1rem,1.6vw,2.5rem)] lg:grid-cols-[calc(50%_-_clamp(7.5rem,11.5vw,21rem))_1fr]">
        <div class="relative">
          <div class="flex min-h-screen flex-col pt-[clamp(3.5rem,7vh,6.5rem)] pr-[clamp(2rem,5.2vw,7rem)] lg:sticky lg:top-0 lg:h-screen">
            <p
              data-fw-label
              data-fw-hide
              class="mb-6 font-mono text-[10px] uppercase tracking-[0.06em]"
            >
              Featured Work / YR {lo}–{hi}
            </p>
            <h2
              data-fw-title
              data-fw-hide
              class="font-normal leading-[1.1] tracking-[-0.5px] text-[clamp(1.5rem,2.1vw,2.6rem)]"
            >
              {first.data.title}
            </h2>
            <p
              data-fw-desc
              data-fw-hide
              class="mt-5 leading-[1.4] text-[clamp(0.8rem,0.9vw,1.1rem)] text-[#666666]"
            >
              {first.data.description}
            </p>

            <div class="absolute bottom-10 left-0 hidden lg:block">
              <div data-fw-dots class="relative flex items-center gap-[10px]">
                {featured.map(() => (
                  <span class="h-[7px] w-[7px] border border-black/30" />
                ))}
                <span
                  data-fw-active
                  class="absolute left-0 top-1/2 h-[7px] w-[7px] -translate-y-1/2 bg-[#0a0a0a]"
                />
              </div>
            </div>
          </div>
        </div>

        <div class="flex flex-col gap-[clamp(2rem,5.5vh,5.5rem)] pt-[clamp(3.5rem,7vh,6.5rem)] pb-[clamp(6rem,16vh,14rem)]">
          {featured.map((p, i) => (
            <a
              href={`/work/${p.id}`}
              data-fw-item
              data-curtain-link
              data-index={i}
              data-title={p.data.title}
              data-desc={p.data.description}
              class="fw-item group block"
            >
              <div
                data-reveal
                class="relative aspect-[16/10] w-full overflow-hidden bg-neutral-300"
              >
                <img
                  src={url(p.data.thumbnail)}
                  alt={p.data.title}
                  class="absolute inset-0 h-full w-full object-cover"
                />
                {url(p.data.thumbnailHover) && (
                  <img
                    src={url(p.data.thumbnailHover)}
                    alt=""
                    aria-hidden="true"
                    class="absolute inset-0 h-full w-full object-cover opacity-0 transition-opacity duration-500 ease-out group-hover:opacity-100 motion-reduce:transition-none"
                  />
                )}
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>
  )
}
