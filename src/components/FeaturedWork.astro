---
import { getCollection } from "astro:content";
import SmartImage from "./SmartImage.astro";

const featured = (
  await getCollection("projects", ({ data }) => data.featured && !data.draft)
).sort((a, b) => b.data.year - a.data.year);

const first = featured[0];
const years = featured.map((f) => f.data.year);
const lo = String(Math.min(...years) % 100).padStart(2, "0");
const hi = String(Math.max(...years) % 100).padStart(2, "0");
---

{
  featured.length > 0 && (
    <section
      data-featured
      class="relative bg-[#e2e2e2] px-[clamp(1rem,1.6vw,2.5rem)] text-[#0a0a0a]"
    >
      {/* Left column ends at the hero portrait's left edge: 50% minus half the portrait width */}
      <div class="grid w-full lg:grid-cols-[calc(50%_-_clamp(7.5rem,11.5vw,21rem))_1fr]">
        <div class="relative">
          <div class="flex min-h-screen flex-col pt-[140px] pr-[clamp(1.5rem,4vw,5rem)] lg:sticky lg:top-0 lg:h-screen">
            <p class="mb-6 font-mono text-[10px] uppercase tracking-[0.06em]">
              Featured Work / YR {lo}–{hi}
            </p>
            <h2
              data-fw-title
              data-fw-hide
              class="font-normal leading-[1.1] tracking-[-0.5px] text-[clamp(1.375rem,1.8vw,2.25rem)]"
            >
              {first.data.title}
            </h2>
            <p
              data-fw-desc
              data-fw-hide
              class="mt-5 max-w-md leading-[1.5] text-[clamp(0.8rem,0.9vw,1.1rem)] text-[#666666]"
            >
              {first.data.description}
            </p>

            <div class="absolute bottom-10 left-0 hidden lg:block">
              <div data-fw-dots class="relative flex items-center gap-[10px]">
                {featured.map(() => (
                  <span class="h-[7px] w-[7px] border border-black/30" />
                ))}
                <span
                  data-fw-active
                  class="absolute left-0 top-1/2 h-[7px] w-[7px] -translate-y-1/2 bg-[#0a0a0a]"
                />
              </div>
            </div>
          </div>
        </div>

        <div class="flex flex-col gap-[clamp(3rem,8vh,8rem)] py-[clamp(6rem,16vh,14rem)]">
          {featured.map((p, i) => (
            <a
              href={`/work/${p.id}`}
              data-fw-item
              data-index={i}
              data-title={p.data.title}
              data-desc={p.data.description}
              class="fw-item block"
            >
              <div
                data-reveal
                class="fw-thumb aspect-[16/10] w-full overflow-hidden bg-neutral-300"
              >
                <SmartImage
                  src={p.data.thumbnail}
                  alt={p.data.title}
                  widths={[600, 1000, 1600]}
                  sizes="60vw"
                  class="h-full w-full object-cover"
                />
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>
  )
}
