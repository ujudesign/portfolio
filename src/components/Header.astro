---
// Fixed status bar. `mix-blend-difference` keeps the text legible over both the
// dark hero and the lighter sections below, flipping black/white automatically.
---

<header id="top" class="fixed inset-x-0 top-0 z-50">
  <div
    class="flex w-full items-center justify-between gap-4 px-[clamp(1rem,1.6vw,2.5rem)] py-4 font-mono text-[10px] uppercase tracking-[0.06em] text-muted"
  >
    <span data-status-item>Suthan / Product Designer</span>
    <span data-status-item class="hidden md:block">Currently at Ferrazcreative</span>
    <span data-status-item id="clock" class="hidden md:block">MTL, QC</span>
    <span data-status-item>Available for Freelance</span>
  </div>
</header>

<script>
  // Live local time in Montreal, updating every second.
  function tick() {
    const el = document.getElementById("clock");
    if (!el) return;
    const time = new Intl.DateTimeFormat("en-US", {
      hour: "2-digit",
      minute: "2-digit",
      second: "2-digit",
      hour12: true,
      timeZone: "America/Toronto",
    }).format(new Date());
    el.textContent = `${time} / MTL, QC`;
  }
  tick();
  setInterval(tick, 1000);
</script>
